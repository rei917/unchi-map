# ============================================================
# .env.local
# 環境変数テンプレート（実際の値を設定してください）
# このファイルは .gitignore に追加して公開しないこと！
# ============================================================

# NextAuth シークレット（ランダムな文字列）
# 生成コマンド: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# NextAuth URL（開発時はそのまま）
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# 取得先: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# サイト入場用の固定招待コード（未設定時は UNCHI-7Q2M）
NEXT_PUBLIC_SITE_INVITE_CODE=UNCHI-7Q2M
